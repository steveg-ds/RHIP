    "from dotenv import load_dotenv\n",
    "from os import getenv\n",
    "from utils import CensusDataLoader\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "load_dotenv()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "df94c89a",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Census API key has been set for this session.\n"
     ]
    }
   ],
   "source": [
    "acs_loader = CensusDataLoader(api_key=getenv(\"CENSUS_API_KEY\"))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "366ce031",
   "metadata": {},
   "outputs": [],
   "source": [
    "MOBILITY_VARS = {\"MOBILITY_TOTAL\": \"B07012_002E\", \"SAME_HOUSE\": \"B07012_006E\", \"MOVED_SAME_COUNTY\": \"B07012_010E\", \"MOVED_DIFF_COUNTY\": \"B07012_014E\", \"MOVED_DIFF_STATE\": \"B07012_018E\", \"MOVED_ABROAD\": \"B07012_022E\"}\n",
    "SNAP_VARS = {\"SNAP_TOTAL\": \"B22003_001E\", \"RECEIVING\": \"B22003_002E\"}\n",
    "EMPLOYMENT_VARS = {\"LABOR_FORCE\": \"B23025_002E\", \"UNEMPLOYED\": \"B23025_005E\"}\n",
    "EDUCATION_VARS = {\"EDU_TOTAL\": \"B15003_001E\", \"GRADES\": [f\"B15003_{num:03d}E\" for num in range(2, 17)]}\n",
    "QUALITY_VARS = {\"PLUMB_TOTAL\": \"B25047_001E\", \"LACK_PLUMBING\": \"B25047_003E\", \"KITCH_TOTAL\": \"B25051_001E\", \"LACK_KITCHEN\": \"B25051_003E\"}\n",
    "POVERTY_VARS = {\"POV_TOTAL\": \"B17001_001E\", \"POVERTY\": \"B17001_002E\"}\n",
    "MORTGAGE_VARS = {\"MORT_TOTAL\": \"B25091_001E\", \"MORT_30_35\": \"B25091_008E\", \"MORT_35_40\": \"B25091_009E\", \"MORT_40_50\": \"B25091_010E\", \"MORT_50_PLUS\": \"B25091_011E\", \"NO_MORT_30_35\": \"B25091_019E\", \"NO_MORT_35_40\": \"B25091_020E\", \"NO_MORT_40_50\": \"B25091_021E\", \"NO_MORT_50_PLUS\": \"B25091_022E\"}\n",
    "RENT_VARS = {\"RENT_TOTAL\": \"B25070_001E\", \"RENT_30_35\": \"B25070_007E\", \"RENT_35_40\": \"B25070_008E\", \"RENT_40_50\": \"B25070_009E\", \"RENT_50_PLUS\": \"B25070_010E\"}\n",
    "MISC_VARS = {\"GINI\": \"B19083_001E\"}\n",
    "\n",
    "all_vars_dict = {}\n",
    "for d in [MOBILITY_VARS, SNAP_VARS, EMPLOYMENT_VARS, EDUCATION_VARS, QUALITY_VARS, POVERTY_VARS, MORTGAGE_VARS, RENT_VARS, MISC_VARS]:\n",
    "    for key, val in d.items():\n",
    "        if isinstance(val, list):\n",
    "            for i, item in enumerate(val): all_vars_dict[f\"{key}_{i}\"] = item\n",
    "        else: all_vars_dict[key] = val"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "b568d7ed",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Combine all variables into a single dictionary\n",
    "all_vars_dict = {}\n",
    "\n",
    "for d in [\n",
    "    MOBILITY_VARS,\n",
    "    SNAP_VARS,\n",
    "    EMPLOYMENT_VARS,\n",
    "    EDUCATION_VARS,\n",
    "    QUALITY_VARS,\n",
    "    POVERTY_VARS,\n",
    "    MORTGAGE_VARS,\n",
    "    RENT_VARS,\n",
    "]:\n",
    "    for key, val in d.items():\n",
    "        if isinstance(val, list):\n",
    "            for i, item in enumerate(val):\n",
    "                all_vars_dict[f\"{key}_{i}\"] = item\n",
    "        else:\n",
    "            all_vars_dict[key] = val"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "id": "90b9e109",
   "metadata": {},
   "outputs": [],
   "source": [
    "acs_data = acs_loader.fetch_multiple(variables=all_vars_dict)"
   ]
  },
